# Cargo build artifacts
/target/

# Tauri permissions schemas (generated per-build)
/gen/schemas/

# Bundles + builds
/release/

# Android project — COMMITTED so customizations (JitPack repo,
# Firebase google-services.json, manifest tweaks, signing config)
# survive teammate clones and CI. Build outputs only are ignored.
gen/android/.gradle/
gen/android/.idea/
gen/android/local.properties
gen/android/build/
gen/android/app/build/
gen/android/captures/
gen/android/.cxx/
gen/android/*.iml
gen/android/app/*.iml

# iOS project — same rationale: committed so signing certs, Firebase
# GoogleService-Info.plist, Info.plist tweaks survive. Xcode build
# outputs ignored.
gen/apple/build/
gen/apple/DerivedData/
gen/apple/*/Build/
gen/apple/Pods/
gen/apple/.swiftpm/
gen/apple/xcuserdata/
gen/apple/*.xcodeproj/xcuserdata/
gen/apple/*.xcodeproj/project.xcworkspace/xcuserdata/
gen/apple/*.xcworkspace/xcuserdata/
