# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# build output
/dist
/build

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the template, ignore the real one
.env*
!.env.example

# vercel
.vercel

# macOS
.DS_Store

# typescript
*.tsbuildinfo

# Local dev TLS certs (mkcert / vite https) — each machine generates its own.
*.pem
/cert/
