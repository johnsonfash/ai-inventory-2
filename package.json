{
  "name": "pallio",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node ip.js && vite --port 3210 --host",
    "build": "tsc --noEmit && vite build",
    "build:analyze": "ANALYZE=1 npm run build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "https": "cloudflared tunnel --protocol http2 --url http://127.0.0.1:3000",
    "https2": "ssh -R 80:127.0.0.1:3000 serveo.net",
    "assets:generate": "node assets/build-icon.mjs && node assets/build-splash.mjs && npx capacitor-assets generate && node assets/fix-cap-assets.mjs",
    "build:native": "node ip.js && npm run build && npx cap sync",
    "cap:sync": "npx cap sync",
    "cap:doctor": "npx cap doctor",
    "ios:add": "npx cap add ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npx cap run ios",
    "ios:build": "npm run build:native && npx cap run ios",
    "ios:clean": "xcodebuild -workspace ios/App/App.xcworkspace -scheme App clean",
    "ios:fresh": "npm run ios:clean && npm run build:native && npx cap run ios",
    "android:add": "npx cap add android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:build": "npm run build:native && npx cap run android",
    "android:clean": "cd android && ./gradlew clean",
    "android:fresh": "npm run android:clean && npm run build:native && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-native-biometric": "^8.4.5",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.39.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "tar": "^7.4.3",
    "minimatch": "^9.0.5"
  }
}
