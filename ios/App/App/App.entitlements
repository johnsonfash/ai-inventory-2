<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Universal links from pallio.app land in the app. Requires
	     a /.well-known/apple-app-site-association file on the
	     domain (see CAPACITOR.md). Until that file is published,
	     iOS treats the link as a normal Safari URL.

	     The aps-environment key isn't required here; push lives in
	     a separate entitlement when/if we wire @capacitor/push-
	     notifications later. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:pallio.app</string>
	</array>
</dict>
</plist>
