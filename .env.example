# Pallio frontend env template — copy to .env.local for local dev.
# `npm run dev` will run `node ip.js` first, which rewrites
# VITE_API_BASE_URL to your current LAN IPv4 so phones / other devices
# on the same Wi-Fi can hit the dev server over HTTPS.
#
# Only VITE_-prefixed vars are exposed to the client bundle.

# Backend API base URL. Frontend is currently dummy-data only — this
# is here for the day the real backend lands.
VITE_API_BASE_URL="https://127.0.0.1:8000/v1"

# Environment label, surfaced in any dev banners / logs.
VITE_ENV="dev"
